<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
   <div class="w-full min-h-screen bg-black text-white p-10">
    <div class="w-full flex justify-end gap-2">
    <a class="bg-yellow-500 px-3 py-2 text-sm mb-5 inline-block rounded-md" href="/profile/upload">Change Profile Picture</a> 
    <a class="bg-red-500 px-3 py-2 text-sm mb-5 inline-block rounded-md" href="/logout">Logout</a> 
    </div>
    <div class="flex items-start gap-3 mb-3">
        <div class="w-10 h-10 rounded-md overflow-hidden">
            <img src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture" class="w-full h-full object-cover ">
        </div>
         <h class="text-4xl tracking-tighter text-green-800">Hey <%= user.username %></h2>
    </div>
   
    <p>Create a post!!!</p>
    
    <form action="/posts" method="post">
        <textarea class=" w-2/3 rounded-md px-3 py-4 bg-zinc-800 resize-none" name="content"  id="post" placeholder="Write your post here..."></textarea>
        <input class="rounded-md mt-2 px-3 py-4 bg-blue-500 block" type="submit" value="Create a post"> 
         
    </form>
    <div class="posts mt-20">
        <h3 class="text-zinc-400">Your Posts are here</h3>
        <div class="postcontainer mt-5">
            <% user.posts.forEach(function(post) { %>
            <div class="post w-1/3 mb-2 p-5 border-2 rounded-md bg-zinc-800 border-zinc-700 ">
                  <h4 class="text-blue-500 mb-2"> Hello <%= user.username %></h4>
                  <p class="text-sm tracking-tighter"><%= post.content %></p>
                  <small class="mt-2 inline-block"><%= post.likes.length %> likes</small>
                  <div class="btns flex gap-4 mt-5">

                    <a class="text-blue-500" href="/like/<%= post._id %>">
                        <%= post.likes.indexOf(user._id) ===-1 ?"Like":"Unlike" %>
                    </a>
                    <a class="text-zinc-400" href="/edit/<%= post._id %>">Edit </a>
                  </div>
             </div>
            
            <% }) %>
        </div>
    </div>
   </div>
</body>
</html>