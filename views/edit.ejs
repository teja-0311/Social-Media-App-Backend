<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
   <div class="w-full min-h-screen bg-black text-white p-10">
    <div class="w-full flex justify-end">
    <a class="bg-red-500 px-3 py-2 text-sm mb-5 inline-block rounded-md" href="/logout">Logout</a> 
    </div>
    <p>Edit your  post!!!</p>
    <form action="/update/<%=post._id%>" method="post">
        <textarea class=" w-2/3 rounded-md px-3 py-4 bg-zinc-800 resize-none" name="content"  id="post" placeholder="Write your post here..."><%= post.content %></textarea>
        <input class="rounded-md mt-2 px-3 py-4 bg-green-500 block" type="submit" value="Update"> 
         
    </form>
   </div>
</body>
</html>