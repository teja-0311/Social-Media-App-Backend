<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
   <div class="w-full min-h-screen bg-black text-white mt-3">
    <form action="/login" method="post">
        <input class="rounded-md px-3 py-4 bg-zinc-800"  type="text" name="email" id="email" placeholder="Email">
        <input class="rounded-md px-3 py-4 bg-zinc-800"  type="password" name="password" id="password" placeholder="Password">
        <input class="rounded-md px-3 py-4 bg-yellow-500" type="submit" value="Login">   
    </form>
   </div>
</body>
</html>